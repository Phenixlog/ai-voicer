# =============================================================================
# Théoria - Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to git!
# =============================================================================

# =============================================================================
# REQUIRED - Mistral AI API
# =============================================================================
MISTRAL_API_KEY=your_mistral_api_key_here

# =============================================================================
# REQUIRED - Database (PostgreSQL)
# =============================================================================
# Format: postgresql://user:password@host:port/database
# Render.com provides this automatically
DATABASE_URL=postgresql://user:pass@host:5432/theoria

# =============================================================================
# REQUIRED - Redis Cache
# =============================================================================
# Format: redis://user:password@host:port/db
# Render.com provides this automatically
REDIS_URL=redis://default:pass@host:6379/0

# =============================================================================
# API Server Configuration
# =============================================================================
AI_VOICER_API_HOST=0.0.0.0
AI_VOICER_API_PORT=8000
AI_VOICER_LOG_LEVEL=INFO

# =============================================================================
# SECURITY - API Authentication
# =============================================================================
# Generate a strong random token:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
AI_VOICER_API_AUTH_TOKEN=your_secure_random_token_here

# =============================================================================
# Mistral Model Configuration
# =============================================================================
# Transcription model (faster, cheaper)
AI_VOICER_TRANSCRIBE_MODEL=voxtral-mini-latest
# AI_VOICER_TRANSCRIBE_MODEL=voxtral-large-latest  # Better quality, slower

# Structuring model (for formatting text)
AI_VOICER_STRUCTURE_MODEL=mistral-small-latest
# AI_VOICER_STRUCTURE_MODEL=mistral-medium-latest  # Better quality

# =============================================================================
# Transcription Settings
# =============================================================================
# Language hint for transcription (ISO 639-1)
AI_VOICER_LANGUAGE=fr
# AI_VOICER_LANGUAGE=en
# AI_VOICER_LANGUAGE=auto  # Auto-detect (slower)

# Context bias (business, medical, legal, etc.)
AI_VOICER_CONTEXT_BIAS=

# Enable text structuring (formatting, punctuation)
AI_VOICER_ENABLE_STRUCTURING=true

# =============================================================================
# Rate Limiting & Performance
# =============================================================================
# Max requests per minute per API key
RATE_LIMIT_PER_MINUTE=60

# Max audio file size (MB)
MAX_AUDIO_SIZE_MB=25

# Request timeout (seconds)
REQUEST_TIMEOUT=60

# =============================================================================
# Monitoring & Observability
# =============================================================================
# Logtail/BetterStack token for centralized logging
LOGTAIL_TOKEN=

# Sentry DSN for error tracking
SENTRY_DSN=

# =============================================================================
# AWS S3 (for audio file storage - optional)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=theoria-audio-uploads

# =============================================================================
# Feature Flags
# =============================================================================
# Enable structured logging (JSON)
ENABLE_JSON_LOGGING=true

# Enable request ID tracking
ENABLE_REQUEST_ID=true

# Enable CORS (for web dashboard)
ENABLE_CORS=true
CORS_ORIGINS=https://app.theoria.app,https://theoria.app

# =============================================================================
# Stripe (for payments - future)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PRO=

# =============================================================================
# Email (for notifications - future)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@theoria.app
